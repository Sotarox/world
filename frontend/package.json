{
  "name": "world-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "pack": "next build && rimraf ../backend/src/main/resources/static/* && shx mv ./build/* ../backend/src/main/resources/static",
    "start": "npx serve@latest ./build",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
